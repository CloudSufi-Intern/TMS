# =============================================================
# TMS Backend — environment configuration
# Copy to `.env` and fill in real values for local dev.
# DO NOT commit `.env` itself.
# =============================================================

# Database (use a free MySQL provider like Aiven or Railway)
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/TMS?createDatabaseIfNotExist=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=
SPRING_JPA_DDL_AUTO=update

# JWT — generate a 64+ char random string for production
JWT_SECRET=replace-me-with-a-strong-random-string-of-at-least-64-characters
JWT_EXPIRATION=86400000

# Mail — Gmail with an App Password
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
[email protected]
MAIL_PASSWORD=your-gmail-app-password

# Frontend URL — used by email links and CORS
TMS_BASE_URL=http://localhost:5173
TMS_CORS_ALLOWED_ORIGINS=http://localhost:5173

# Upload size cap
TMS_MAX_ATTACHMENT_BYTES=16777216
MAX_FILE_SIZE=16MB
MAX_REQUEST_SIZE=32MB

# Server port (Render sets PORT automatically)
PORT=8080
